<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Roehampton Sustainable Futures Hub</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --forest: #1a3a2a;
    --leaf: #2d6a4f;
    --sage: #52b788;
    --mint: #b7e4c7;
    --cream: #f8f5ee;
    --warm-white: #fdfaf4;
    --charcoal: #1c1c1c;
    --muted: #5a6a60;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: 'DM Sans', sans-serif; background: var(--warm-white); color: var(--charcoal); }

/* ── NAV ── */
nav {
position: fixed; top: 0; left: 0; right: 0; z-index: 200;
display: flex; align-items: center; justify-content: space-between;
padding: 1rem 3rem;
background: rgba(248,245,238,0.95);
backdrop-filter: blur(16px);
border-bottom: 1px solid rgba(45,106,79,0.12);
}
.nav-logo { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; }
.nav-logo-text { font-size: 0.75rem; font-weight: 500; color: var(–forest); line-height: 1.3; text-transform: uppercase; letter-spacing: 0.04em; }
.nav-links { display: flex; gap: 0; list-style: none; align-items: center; }
.nav-links a {
text-decoration: none; font-size: 0.8rem; font-weight: 500; color: var(–muted);
letter-spacing: 0.04em; text-transform: uppercase; padding: 0.5rem 1.1rem;
transition: color 0.2s; border-radius: 6px;
}
.nav-links a:hover { color: var(–leaf); background: rgba(82,183,136,0.08); }
.nav-cta {
background: var(–forest) !important; color: var(–mint) !important;
padding: 0.6rem 1.4rem !important; border-radius: 100px !important; margin-left: 0.5rem;
}
.nav-cta:hover { background: var(–leaf) !important; color: white !important; }

/* ── MOBILE NAV ── */
.hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 5px; }
.hamburger span { width: 22px; height: 2px; background: var(–forest); border-radius: 2px; transition: all 0.3s; }
@media (max-width: 900px) {
.hamburger { display: flex; }
.nav-links { display: none; flex-direction: column; position: absolute; top: 100%; left: 0; right: 0; background: var(–cream); border-bottom: 1px solid rgba(45,106,79,0.12); padding: 1rem; gap: 0.25rem; }
.nav-links.open { display: flex; }
.nav-links a { padding: 0.75rem 1rem; border-radius: 8px; }
nav { padding: 1rem 1.5rem; }
}

/* ── HERO ── */
.hero {
min-height: 100vh; display: grid; grid-template-columns: 1fr 1fr;
padding-top: 70px; overflow: hidden;
}
.hero-left {
display: flex; flex-direction: column; justify-content: center;
padding: 5rem 3rem 5rem 3.5rem;
}
.hero-badge {
display: inline-flex; align-items: center; gap: 0.5rem;
background: var(–mint); color: var(–forest);
padding: 0.35rem 1rem; border-radius: 100px;
font-size: 0.7rem; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase;
margin-bottom: 1.75rem; width: fit-content;
animation: fadeUp 0.7s ease both;
}
.hero-badge::before { content: ‘’; width: 6px; height: 6px; background: var(–leaf); border-radius: 50%; }
h1.hero-title {
font-family: ‘Playfair Display’, serif; font-size: clamp(2.6rem,4vw,3.8rem);
font-weight: 900; line-height: 1.08; color: var(–forest); margin-bottom: 1.25rem;
animation: fadeUp 0.7s 0.1s ease both;
}
h1.hero-title em { font-style: italic; color: var(–leaf); }
.hero-desc {
font-size: 1rem; line-height: 1.8; color: var(–muted); max-width: 460px;
margin-bottom: 2.25rem; font-weight: 300;
animation: fadeUp 0.7s 0.2s ease both;
}
.hero-actions { display: flex; gap: 1rem; animation: fadeUp 0.7s 0.3s ease both; flex-wrap: wrap; }
.btn-primary {
background: var(–forest); color: var(–mint); padding: 0.9rem 2rem;
border-radius: 100px; font-size: 0.85rem; font-weight: 500; text-decoration: none;
transition: all 0.25s; display: inline-block;
}
.btn-primary:hover { background: var(–leaf); color: white; transform: translateY(-2px); box-shadow: 0 8px 30px rgba(45,106,79,0.3); }
.btn-outline {
background: transparent; color: var(–forest); padding: 0.9rem 2rem;
border-radius: 100px; font-size: 0.85rem; font-weight: 500; text-decoration: none;
border: 1.5px solid var(–forest); transition: all 0.25s; display: inline-block;
}
.btn-outline:hover { background: var(–forest); color: var(–mint); transform: translateY(-2px); }
.hero-pillars { margin-top: 3rem; display: flex; gap: 2rem; animation: fadeUp 0.7s 0.4s ease both; }
.pillar { display: flex; flex-direction: column; gap: 0.3rem; }
.pillar-label { font-size: 0.65rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; color: var(–sage); }
.pillar-value { font-family: ‘Playfair Display’, serif; font-size: 1.3rem; font-weight: 700; color: var(–forest); }
.pillar-divider { width: 1px; background: var(–mint); align-self: stretch; }
.hero-right { position: relative; overflow: hidden; background: var(–forest); }
.hero-visual {
width: 100%; height: 100%;
background: linear-gradient(135deg, #1a3a2a 0%, #2d6a4f 45%, #52b788 100%);
display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden;
}
.hero-network { position: absolute; inset: 0; opacity: 0.18; }
.hero-orb { position: absolute; border-radius: 50%; filter: blur(60px); opacity: 0.25; animation: pulse 8s ease-in-out infinite; }
.orb-1 { width: 280px; height: 280px; background: var(–sage); top: -40px; right: -60px; }
.orb-2 { width: 180px; height: 180px; background: #d4a843; bottom: 40px; left: -50px; animation-delay: -4s; }
.hero-card {
position: relative; z-index: 2;
background: rgba(248,245,238,0.1); backdrop-filter: blur(20px);
border: 1px solid rgba(183,228,199,0.3); border-radius: 20px;
padding: 2rem; width: 300px; animation: float 6s ease-in-out infinite;
}
.hero-card-title { font-family: ‘Playfair Display’, serif; font-size: 1rem; color: var(–mint); margin-bottom: 1rem; }
.hero-card-item { display: flex; align-items: center; gap: 0.7rem; color: rgba(183,228,199,0.85); font-size: 0.82rem; font-weight: 300; margin-bottom: 0.6rem; }
.hero-card-dot { width: 7px; height: 7px; background: var(–sage); border-radius: 50%; flex-shrink: 0; }

/* ── SHARED SECTION STYLES ── */
.section-label { font-size: 0.7rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(–sage); margin-bottom: 0.75rem; }
.section-title { font-family: ‘Playfair Display’, serif; font-size: clamp(1.9rem,2.8vw,2.6rem); font-weight: 900; line-height: 1.15; color: var(–forest); margin-bottom: 1.25rem; }
.section-title em { font-style: italic; color: var(–leaf); }
.section-body { font-size: 0.95rem; line-height: 1.8; color: var(–muted); font-weight: 300; }

/* ── WHY ── */
.why {
padding: 6rem 3.5rem; display: grid; grid-template-columns: 1fr 1.5fr;
gap: 5rem; align-items: center; background: var(–cream); position: relative; overflow: hidden;
}
.why::before {
content: ‘’; position: absolute; top: -80px; right: -80px;
width: 320px; height: 320px;
background: radial-gradient(circle, var(–mint) 0%, transparent 70%);
opacity: 0.4; border-radius: 50%;
}
.why-values { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
.value-card {
background: white; border-radius: 14px; padding: 1.5rem;
border: 1px solid rgba(45,106,79,0.1); transition: all 0.3s; position: relative; overflow: hidden;
}
.value-card::after {
content: ‘’; position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
background: linear-gradient(90deg, var(–leaf), var(–sage));
transform: scaleX(0); transform-origin: left; transition: transform 0.3s;
}
.value-card:hover { transform: translateY(-4px); box-shadow: 0 10px 36px rgba(26,58,42,0.1); }
.value-card:hover::after { transform: scaleX(1); }
.value-icon-wrap { width: 36px; height: 36px; background: var(–mint); border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-bottom: 0.75rem; }
.value-title { font-family: ‘Playfair Display’, serif; font-size: 0.95rem; font-weight: 700; color: var(–forest); margin-bottom: 0.4rem; }
.value-desc { font-size: 0.8rem; color: var(–muted); line-height: 1.6; }

/* ── PROJECTS ── */
.projects { padding: 6rem 3.5rem; background: var(–warm-white); }
.projects-header { text-align: center; margin-bottom: 3.5rem; }
.projects-header .section-body { max-width: 520px; margin: 0 auto; }
.projects-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; margin-bottom: 1.5rem; }
.project-card {
border-radius: 18px; overflow: hidden; background: white;
border: 1px solid rgba(45,106,79,0.1); transition: all 0.35s; cursor: pointer;
}
.project-card:hover { transform: translateY(-6px); box-shadow: 0 20px 50px rgba(26,58,42,0.13); }
.project-visual { height: 160px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
.pv-1 { background: linear-gradient(135deg,#1a3a2a,#2d6a4f); }
.pv-2 { background: linear-gradient(135deg,#1a3d6e,#2e6bb5); }
.pv-3 { background: linear-gradient(135deg,#3a2a1a,#8a5c2a); }
.project-visual-tag {
position: absolute; top: 0.75rem; left: 0.75rem;
background: rgba(255,255,255,0.18); color: white; font-size: 0.62rem;
font-weight: 500; letter-spacing: 0.07em; text-transform: uppercase;
padding: 0.25rem 0.7rem; border-radius: 100px; backdrop-filter: blur(8px);
}
.project-logo-area { display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 0.5rem; }
.project-body { padding: 1.5rem; }
.project-number { font-size: 0.62rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(–sage); margin-bottom: 0.4rem; }
.project-title { font-family: ‘Playfair Display’, serif; font-size: 1rem; font-weight: 700; color: var(–forest); line-height: 1.3; margin-bottom: 0.65rem; }
.project-desc { font-size: 0.8rem; line-height: 1.7; color: var(–muted); margin-bottom: 1rem; }
.project-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.tag-pill { background: var(–mint); color: var(–forest); font-size: 0.65rem; font-weight: 500; padding: 0.22rem 0.65rem; border-radius: 100px; }
.project-partners-strip { padding: 1rem 1.5rem; border-top: 1px solid rgba(45,106,79,0.08); display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
.project-partners-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(–muted); font-weight: 500; }

/* ── PILOT ── */
.pilot-card {
border-radius: 18px; overflow: hidden; display: grid; grid-template-columns: 1fr 1fr;
background: var(–forest); border: 1px solid rgba(82,183,136,0.2); transition: transform 0.3s;
}
.pilot-card:hover { transform: translateY(-4px); }
.pilot-left { padding: 2.5rem; display: flex; flex-direction: column; justify-content: center; }
.pilot-badge {
display: inline-flex; align-items: center; gap: 0.5rem;
background: rgba(183,228,199,0.15); color: var(–mint);
padding: 0.3rem 0.9rem; border-radius: 100px; font-size: 0.62rem;
font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
margin-bottom: 1rem; width: fit-content; border: 1px solid rgba(183,228,199,0.25);
}
.pilot-title { font-family: ‘Playfair Display’, serif; font-size: 1.35rem; font-weight: 700; color: white; line-height: 1.25; margin-bottom: 0.9rem; }
.pilot-desc { font-size: 0.85rem; line-height: 1.75; color: rgba(183,228,199,0.75); margin-bottom: 1.25rem; font-weight: 300; }
.pilot-highlight {
display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.78rem; color: var(–mint);
padding: 0.75rem 1rem; background: rgba(82,183,136,0.12); border-radius: 10px; border-left: 3px solid var(–sage);
}
.pilot-right {
padding: 2.5rem; display: flex; flex-direction: column; justify-content: center; gap: 0.9rem;
background: rgba(82,183,136,0.05); border-left: 1px solid rgba(82,183,136,0.15);
}
.pilot-stat { padding: 1rem 1.25rem; background: rgba(255,255,255,0.05); border-radius: 10px; border: 1px solid rgba(82,183,136,0.15); }
.pilot-stat-value { font-family: ‘Playfair Display’, serif; font-size: 1.6rem; font-weight: 700; color: var(–mint); line-height: 1; margin-bottom: 0.25rem; }
.pilot-stat-label { font-size: 0.75rem; color: rgba(183,228,199,0.6); font-weight: 300; }

/* ── TEAM SECTION ── */
.team { padding: 6rem 3.5rem; background: var(–cream); }
.team-header { text-align: center; margin-bottom: 3rem; }
.team-tabs { display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2.5rem; }
.team-tab {
padding: 0.55rem 1.25rem; border-radius: 100px; font-size: 0.78rem; font-weight: 500;
cursor: pointer; border: 1.5px solid rgba(45,106,79,0.2); background: white;
color: var(–muted); transition: all 0.2s;
}
.team-tab.active { background: var(–forest); color: var(–mint); border-color: var(–forest); }
.team-tab:hover:not(.active) { border-color: var(–sage); color: var(–leaf); }
.team-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem; }
.team-card {
background: white; border-radius: 14px; overflow: hidden;
border: 1px solid rgba(45,106,79,0.1); transition: all 0.3s;
}
.team-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(26,58,42,0.1); }
.team-card-img { height: 160px; background: linear-gradient(135deg, var(–mint), rgba(82,183,136,0.3)); display: flex; align-items: center; justify-content: center; overflow: hidden; }
.team-card-img img { width: 100%; height: 100%; object-fit: cover; object-position: top; }
.team-avatar { width: 64px; height: 64px; background: var(–forest); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: ‘Playfair Display’, serif; font-size: 1.4rem; font-weight: 700; color: var(–mint); }
.team-card-body { padding: 1.25rem; }
.team-name { font-family: ‘Playfair Display’, serif; font-size: 0.95rem; font-weight: 700; color: var(–forest); margin-bottom: 0.2rem; }
.team-role { font-size: 0.72rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: var(–sage); margin-bottom: 0.6rem; }
.team-bio { font-size: 0.78rem; line-height: 1.65; color: var(–muted); }
.team-panel { display: none; }
.team-panel.active { display: block; }

/* ── IMPACT ── */
.impact { padding: 6rem 3.5rem; background: var(–forest); text-align: center; position: relative; overflow: hidden; }
.impact::before {
content: ‘’; position: absolute; inset: 0;
background: radial-gradient(ellipse at 25% 50%, rgba(82,183,136,0.15) 0%, transparent 55%),
radial-gradient(ellipse at 80% 20%, rgba(212,168,67,0.1) 0%, transparent 50%);
}
.impact-header { position: relative; z-index: 1; margin-bottom: 3.5rem; }
.impact-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 2px; position: relative; z-index: 1; background: rgba(82,183,136,0.15); border-radius: 18px; overflow: hidden; margin-bottom: 3rem; }
.impact-stat { padding: 2.5rem 1.5rem; background: rgba(26,58,42,0.92); display: flex; flex-direction: column; align-items: center; transition: background 0.3s; }
.impact-stat:hover { background: rgba(45,106,79,0.9); }
.impact-number { font-family: ‘Playfair Display’, serif; font-size: 2.8rem; font-weight: 900; color: var(–sage); line-height: 1; margin-bottom: 0.4rem; }
.impact-label { font-size: 0.78rem; color: rgba(183,228,199,0.7); font-weight: 300; text-align: center; line-height: 1.5; }
.principles { display: grid; grid-template-columns: repeat(5,1fr); gap: 0.75rem; position: relative; z-index: 1; }
.principle { padding: 1.1rem; border: 1px solid rgba(82,183,136,0.2); border-radius: 10px; font-size: 0.78rem; color: rgba(183,228,199,0.75); display: flex; align-items: center; gap: 0.5rem; }
.principle-dot { width: 6px; height: 6px; background: var(–sage); border-radius: 50%; flex-shrink: 0; }

/* ── PARTNERS ── */
.partners { padding: 5rem 3.5rem; background: var(–warm-white); text-align: center; }
.partners-header { margin-bottom: 3rem; }
.partners-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1.25rem; margin-bottom: 2rem; }
.partner-card {
background: white; border-radius: 14px; padding: 1.75rem 1.25rem;
border: 1px solid rgba(45,106,79,0.1); transition: all 0.3s; display: flex; flex-direction: column; align-items: center; gap: 0.75rem;
}
.partner-card:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(26,58,42,0.08); }
.partner-logo-area { height: 50px; display: flex; align-items: center; justify-content: center; }
.partner-name { font-family: ‘Playfair Display’, serif; font-size: 0.9rem; font-weight: 700; color: var(–forest); }
.partner-desc { font-size: 0.76rem; color: var(–muted); line-height: 1.6; text-align: center; }
.funders-row { display: flex; align-items: center; justify-content: center; gap: 2rem; flex-wrap: wrap; padding: 1.5rem; background: var(–cream); border-radius: 14px; }
.funder-item { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; }
.funder-name { font-size: 0.72rem; font-weight: 500; color: var(–muted); text-transform: uppercase; letter-spacing: 0.05em; }

/* ── CONTACT ── */
.contact { padding: 6rem 3.5rem; background: var(–cream); display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
.contact-motto { font-family: ‘Playfair Display’, serif; font-size: 1.4rem; font-style: italic; color: var(–sage); margin: 1.25rem 0; }
.contact-details { display: flex; flex-direction: column; gap: 0.9rem; margin-top: 1.75rem; }
.contact-detail { display: flex; align-items: center; gap: 0.9rem; font-size: 0.86rem; color: var(–muted); }
.contact-detail-icon { width: 34px; height: 34px; background: var(–mint); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.contact-form { background: white; border-radius: 22px; padding: 2.25rem; border: 1px solid rgba(45,106,79,0.1); box-shadow: 0 4px 24px rgba(26,58,42,0.05); }
.form-title { font-family: ‘Playfair Display’, serif; font-size: 1.2rem; font-weight: 700; color: var(–forest); margin-bottom: 1.5rem; }
.form-group { margin-bottom: 1rem; }
.form-label { display: block; font-size: 0.72rem; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; color: var(–muted); margin-bottom: 0.4rem; }
.form-input {
width: 100%; padding: 0.7rem 0.9rem;
border: 1.5px solid rgba(45,106,79,0.15); border-radius: 9px;
font-family: ‘DM Sans’, sans-serif; font-size: 0.88rem; color: var(–charcoal);
background: var(–warm-white); outline: none; transition: border-color 0.2s;
}
.form-input:focus { border-color: var(–sage); background: white; }
.form-input::placeholder { color: rgba(90,106,96,0.45); }
textarea.form-input { resize: vertical; min-height: 90px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.9rem; }
.form-submit {
width: 100%; padding: 0.95rem; background: var(–forest); color: var(–mint);
border: none; border-radius: 100px; font-family: ‘DM Sans’, sans-serif;
font-size: 0.88rem; font-weight: 500; cursor: pointer; transition: all 0.25s; margin-top: 0.4rem;
}
.form-submit:hover { background: var(–leaf); color: white; transform: translateY(-2px); box-shadow: 0 8px 28px rgba(45,106,79,0.3); }

/* ── FOOTER ── */
footer {
background: var(–charcoal); color: rgba(255,255,255,0.45);
padding: 1.75rem 3.5rem; display: flex; align-items: center; justify-content: space-between;
font-size: 0.76rem; flex-wrap: wrap; gap: 0.75rem;
}
footer a { color: var(–sage); text-decoration: none; }

/* ── LOGO SVGS inline ── */
.logo-roehampton { display: flex; align-items: center; gap: 6px; }

/* ── ANIMATIONS ── */
@keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
@keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
@keyframes pulse { 0%,100% { opacity: 0.25; transform: scale(1); } 50% { opacity: 0.4; transform: scale(1.1); } }
.reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
.reveal.visible { opacity: 1; transform: none; }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
.hero { grid-template-columns: 1fr; }
.hero-right { display: none; }
.why, .contact { grid-template-columns: 1fr; gap: 3rem; }
.projects-grid { grid-template-columns: 1fr 1fr; }
.pilot-card { grid-template-columns: 1fr; }
.impact-grid { grid-template-columns: repeat(2,1fr); }
.principles { grid-template-columns: repeat(3,1fr); }
.partners-grid { grid-template-columns: repeat(2,1fr); }
.team-grid { grid-template-columns: repeat(2,1fr); }
}
@media (max-width: 640px) {
nav { padding: 0.9rem 1.25rem; }
.hero-left { padding: 4rem 1.5rem 3rem; }
.why, .projects, .team, .impact, .partners, .contact { padding: 4rem 1.5rem; }
.projects-grid { grid-template-columns: 1fr; }
.why-values { grid-template-columns: 1fr; }
.impact-grid { grid-template-columns: 1fr 1fr; }
.principles { grid-template-columns: 1fr 1fr; }
.partners-grid { grid-template-columns: 1fr 1fr; }
.team-grid { grid-template-columns: 1fr; }
footer { flex-direction: column; text-align: center; padding: 1.5rem; }
.hero-pillars { gap: 1.25rem; }
.form-row { grid-template-columns: 1fr; }
